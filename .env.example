# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit it.
#
# Usage:
#   cp .env.example .env
#   # edit .env with your values
#   pip install python-dotenv   # or: pip install -e ".[dev]"
#
# The notebooks load this automatically via python-dotenv.
# Set LLM_PROVIDER in the config cell to select which provider to use.

# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Anthropic ────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── Google / Gemini ──────────────────────────────────────────────────────────
# GOOGLE_API_KEY=AIza...

# ── Default provider (used by CIP-000C multi-provider support) ──────────────
# LLM_PROVIDER=openai   # openai | anthropic | google
